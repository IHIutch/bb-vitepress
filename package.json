{
  "name": "bb-vitepress",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:ab2d": "pnpm --filter @bb/ab2d dev",
    "dev:bb2": "pnpm --filter @bb/bb2 dev",
    "dev:bcda": "pnpm --filter @bb/bcda dev",
    "dev:dpc": "pnpm --filter @bb/dpc dev",
    "build:ab2d": "pnpm --filter @bb/ab2d build",
