    "build:bcda": "pnpm --filter @bb/bcda build",
    "build:dpc": "pnpm --filter @bb/dpc build",
    "build:all": "pnpm --filter '@bb/*' build",
    "cf-deploy:ab2d": "pnpm --filter @bb/ab2d cf-deploy",
    "cf-deploy:bb2": "pnpm --filter @bb/bb2 cf-deploy",
    "cf-deploy:bcda": "pnpm --filter @bb/bcda cf-deploy",
    "cf-deploy:dpc": "pnpm --filter @bb/dpc cf-deploy",
    "cf-deploy:all": "pnpm --filter '@bb/*' cf-deploy"
